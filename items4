-- ============================================
-- [PERSISTENT TOOL VAULT - الخزنة الدائمة]
-- الحل الحقيقي: نحفظ الأداة كـ clone ثابت في _G
-- حتى لو ماتت الشخصية أو انحذف كل شيء، الخزنة تبقى
-- ============================================
if not _G.__ToolVault then
    _G.__ToolVault = {}
end
local ToolVault = _G.__ToolVault

local function vaultSave(tool)
    if not tool or not tool:IsA("Tool") then return end
    local name = tool.Name
    -- نحفظ clone جديد فقط إذا ما عندنا واحد أو إذا القديم صار invalid
    if not ToolVault[name] or not ToolVault[name].Parent then
        local ok, clone = pcall(function() return tool:Clone() end)
        if ok and clone then
            clone.CanBeDropped = false
            -- نخبّي الأداة في ReplicatedStorage بدل ما تبقى بدون parent
            -- هذا يمنعها من الانحذاف
            local RS = game:GetService("ReplicatedStorage")
            local vault = RS:FindFirstChild("__ToolVault__")
            if not vault then
                vault = Instance.new("Folder")
                vault.Name = "__ToolVault__"
                vault.Parent = RS
            end
            -- احذف القديم إن وجد
            local old = vault:FindFirstChild(name)
            if old then old:Destroy() end
            clone.Parent = vault
            ToolVault[name] = clone
            if Settings.ShowConsoleLogs then
                print("💾 [محفوظ في الخزنة] " .. name)
            end
        end
    end
end

local function vaultGetAll()
    -- نرجّع قائمة بأسماء كل الأدوات المحفوظة
    local list = {}
    for name, tool in pairs(ToolVault) do
        -- تأكد الـ clone لسه موجود وصحيح
        if tool and tool.Parent then
            list[name] = tool
        else
            -- إذا انحذف من الخزنة بطريقة ما، نشيله
            ToolVault[name] = nil
        end
    end
    return list
end

-- ============================================
-- [RESTORE - استعادة الأدوات من الخزنة]
-- ============================================
local function restoreAllTools()
    task.wait(1.5) -- انتظر تحميل الشخصية والباكباك

    local currentBackpack = player:WaitForChild("Backpack", 5)
    if not currentBackpack then
        print("❌ لم يتم العثور على Backpack")
        return
    end

    local vault = vaultGetAll()
    local restored = 0

    for name, savedTool in pairs(vault) do
        -- تحقق أن الأداة مش موجودة عندي
        local inBackpack = currentBackpack:FindFirstChild(name)
        local inChar = player.Character and player.Character:FindFirstChild(name)

        if not inBackpack and not inChar then
            local ok, clone = pcall(function() return savedTool:Clone() end)
            if ok and clone then
                clone.CanBeDropped = false
                clone.Parent = currentBackpack
                restored = restored + 1
                if Settings.ShowConsoleLogs then
                    print("  ✅ [مُستعادة] " .. name)
                end
            end
        end
    end

    -- كمان نحفظ في StarterGear عشان الموتات الجاية
    if player.StarterGear then
        for name, savedTool in pairs(vault) do
            if not player.StarterGear:FindFirstChild(name) then
                local ok, clone = pcall(function() return savedTool:Clone() end)
                if ok and clone then
                    clone.CanBeDropped = false
                    clone.Parent = player.StarterGear
                end
            end
        end
    end

    if restored > 0 then
        print("🎉 تم استعادة " .. restored .. " أداة من الخزنة!")
    else
        local count = 0
        for _ in pairs(vault) do count = count + 1 end
        if count > 0 then
            print("✅ كل الأدوات موجودة بالفعل (" .. count .. " أداة)")
        end
    end
end

-- ============================================
-- [BLACKLIST & WHITELIST]
-- ============================================
local blacklist = {}
local whitelist = {}

local function isBlacklisted(toolName)
    for _, name in ipairs(blacklist) do
        if toolName:lower():find(name:lower()) then return true end
    end
    return false
end

local function isWhitelisted(toolName)
    if #whitelist == 0 then return true end
    for _, name in ipairs(whitelist) do
        if toolName:lower():find(name:lower()) then return true end
    end
    return false
end

-- ============================================
-- [GET TOOLS FROM TARGET PLAYER]
-- ============================================
local function getPlayerTools(targetPlayer)
    local tools = {}
    local seen = {}
    local count = 0

    local function addTool(child, location)
        if count >= Settings.MaxToolsPerScan then return end
        if child:IsA("Tool") and not seen[child.Name] then
            seen[child.Name] = true
            table.insert(tools, { tool = child, location = location, player = targetPlayer })
            count = count + 1
        end
    end

    if Settings.TransferFromBackpack and targetPlayer.Backpack then
        for _, c in ipairs(targetPlayer.Backpack:GetChildren()) do addTool(c, "Backpack") end
    end

    if Settings.TransferFromCharacter and targetPlayer.Character then
        for _, c in ipairs(targetPlayer.Character:GetChildren()) do addTool(c, "Character") end
    end

    if Settings.TransferFromStarterGear and targetPlayer.StarterGear then
        for _, c in ipairs(targetPlayer.StarterGear:GetChildren()) do addTool(c, "StarterGear") end
    end

    return tools
end

local function getMyCurrentTools()
    local myTools = {}
    for _, c in ipairs(backpack:GetChildren()) do
        if c:IsA("Tool") then myTools[c.Name] = true end
    end
    if player.Character then
        for _, c in ipairs(player.Character:GetChildren()) do
            if c:IsA("Tool") then myTools[c.Name] = true end
        end
    end
    -- كمان تحقق من الخزنة
    for name in pairs(ToolVault) do
        myTools[name] = true
    end
    return myTools
end

-- ============================================
-- [COPY & TRANSFER]
-- ============================================
local function copyTool(tool)
    local clone = tool:Clone()
    clone.CanBeDropped = false
    clone.Parent = backpack
    -- احفظ في الخزنة فوراً
    vaultSave(clone)
    -- احفظ في StarterGear
    if player.StarterGear then
        local old = player.StarterGear:FindFirstChild(tool.Name)
        if old then old:Destroy() end
        local sgClone = tool:Clone()
        sgClone.CanBeDropped = false
        sgClone.Parent = player.StarterGear
    end
    if Settings.AutoEquip and player.Character then
        task.wait(0.1)
        clone.Parent = player.Character
    end
    return clone
end

local function transferTool(toolInfo, myTools)
    local tool = toolInfo.tool
    local name = tool.Name

    if isBlacklisted(name) then return false, "blacklisted" end
    if not isWhitelisted(name) then return false, "not whitelisted" end
    if Settings.CheckDuplicates and myTools[name] then return false, "duplicate" end

    local ok, result = pcall(copyTool, tool)
    if ok and result then
        if Settings.ShowConsoleLogs then
            print("✅ [منقول] " .. name .. " (من " .. toolInfo.player.Name .. " - " .. toolInfo.location .. ")")
        end
        return true, "success", result
    else
        if Settings.ShowConsoleLogs then
            print("❌ [فشل] " .. name)
        end
        return false, "copy failed"
    end
end

-- ============================================
-- [SCAN & TRANSFER ALL]
-- ============================================
local function scanPlayer(targetPlayer, myTools)
    if targetPlayer == player then return { transferred = 0, skipped = 0, tools = {} } end

    if Settings.ShowConsoleLogs then print("🔍 فحص: " .. targetPlayer.Name) end

    local tools = getPlayerTools(targetPlayer)
    local result = { transferred = 0, skipped = 0, tools = {} }

    for _, toolInfo in ipairs(tools) do
        local success, reason, newTool = transferTool(toolInfo, myTools)
        if success then
            result.transferred = result.transferred + 1
            table.insert(result.tools, { name = toolInfo.tool.Name, source = targetPlayer.Name, location = toolInfo.location })
            myTools[toolInfo.tool.Name] = true
        else
            result.skipped = result.skipped + 1
        end
        task.wait(Settings.DelayBetweenTransfers)
    end

    if Settings.ShowConsoleLogs and #tools > 0 then
        print("   📦 وجدت: " .. #tools .. " | ✅ منقول: " .. result.transferred .. " | ⏭️ متخطي: " .. result.skipped)
    end

    return result
end

local function transferAllTools()
    print("")
    print("════════════════════════════════════════")
    print("🚀 بدء عملية نقل الأدوات")
    print("════════════════════════════════════════")

    -- أول شيء: استعد أدوات الخزنة إذا عندنا
    local vaultCount = 0
    for _ in pairs(ToolVault) do vaultCount = vaultCount + 1 end
    if vaultCount > 0 then
        print("💾 عندك " .. vaultCount .. " أداة محفوظة في الخزنة - جاري استعادتها...")
        restoreAllTools()
        task.wait(0.5)
    end

    local myTools = getMyCurrentTools()
    local total = { transferred = 0, skipped = 0, scanned = 0, allTools = {} }

    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        local result = scanPlayer(targetPlayer, myTools)
        total.transferred += result.transferred
        total.skipped += result.skipped
        total.scanned += 1
        for _, t in ipairs(result.tools) do table.insert(total.allTools, t) end
    end

    print("")
    print("════════════════════════════════════════")
    print("📊 تقرير النقل النهائي")
    print("════════════════════════════════════════")
    print("👥 اللاعبين المفحوصين: " .. total.scanned)
    print("✅ الأدوات المنقولة: " .. total.transferred)
    print("⏭️ الأدوات المتخطاة: " .. total.skipped)

    local vaultTotal = 0
    for _ in pairs(ToolVault) do vaultTotal = vaultTotal + 1 end
    print("💾 إجمالي الأدوات في الخزنة: " .. vaultTotal)
    print("════════════════════════════════════════")

    if #total.allTools > 0 then
        print("📦 الأدوات الجديدة المنقولة:")
        for _, t in ipairs(total.allTools) do
            print("   - " .. t.name .. " (من " .. t.source .. ")")
        end
    end

    return total
end

