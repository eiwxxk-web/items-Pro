    print("   ✓ 🔄 مراقبة الباكباك الجديد بعد الموت")
    print("   ✓ ✓ فحص Backpack + Character + StarterGear")
    print("   ✓ تجنب التكرار التلقائي")
    print("════════════════════════════════════════════")
    print("💬 Discord: discord.gg/uKdvZk7G")
    print("════════════════════════════════════════════")

    pcall(createGUI)

    -- احفظ الأدوات الموجودة لدي الآن في الخزنة
    local count = 0
    for _, c in ipairs(backpack:GetChildren()) do
        if c:IsA("Tool") then
            vaultSave(c)
            count = count + 1
        end
    end
    if player.Character then
        for _, c in ipairs(player.Character:GetChildren()) do
            if c:IsA("Tool") then
                vaultSave(c)
                count = count + 1
            end
        end
    end

    print("📋 تم حفظ " .. count .. " أداة موجودة في الخزنة")

    -- تعريف الدوال العامة
    _G.TransferAllTools = transferAllTools
    _G.RestoreTools = restoreAllTools
    _G.ShowVault = function()
        print("💾 الخزنة الدائمة:")
        local n = 0
        for name in pairs(ToolVault) do
            print("   🔐 " .. name)
            n = n + 1
        end
        print("المجموع: " .. n)
    end
    _G.VaultSave = vaultSave

    print("")
    print("💡 الدوال المتاحة في الكونسول:")
    print("   _G.TransferAllTools()  - نقل جميع الأدوات")
    print("   _G.RestoreTools()      - استعادة من الخزنة")
    print("   _G.ShowVault()         - عرض محتوى الخزنة")
    print("════════════════════════════════════════════")
end

repeat task.wait() until player and player.Character
startScript()
