    {84,88,57,45,86,73,80,45,50,48,50,52,45,68,68,68,68},     
    {84,88,57,45,86,73,80,45,50,48,50,52,45,69,69,69,69},    
    {84,88,57,45,86,73,80,45,50,48,50,52,45,70,70,70,70},     
    {84,88,57,45,86,73,80,45,50,48,50,52,45,77,77,77,77},     
    {84,88,57,45,70,82,69,69,45,50,48,50,52,45,65,65,65,65},  
    {84,88,57,45,70,82,69,69,45,50,48,50,52,45,66,66,66,66}, 
    {84,88,57,45,86,73,80,45,50,48,50,52,45,67,67,67,67},     
    {84,88,57,45,77,65,83,84,69,82,45,48,48,48,48},
    {65,68,77,73,78,48},
}

local function decrypt(t)
    local str = ""
    for _, v in ipairs(t) do
        str = str .. string.char(v)
    end
    return str
end

-- فك جميع المفاتيح وإزالة المكررات
local keys = {}
local uniqueKeys = {}

for i, v in ipairs(encryptedKeys) do
    keys[i] = decrypt(v)
end

for _, v in ipairs(keys) do
    local found = false
    for _, u in ipairs(uniqueKeys) do
        if u == v then found = true break end
    end
    if not found then
        table.insert(uniqueKeys, v)
    end
end

local CFG = {
    KEYS = uniqueKeys,
    SITE = "https://tx9-key.netlify.app",
    NAME = "TX9",
}

-- ══════════════════════════════
-- 🛡️ الحماية
-- ══════════════════════════════
local function antiDebug()
    local info = debug and debug.info or nil
    if info and type(info) == "function" then
        error("Debugger detected")
    end
end
pcall(antiDebug)

-- ══════════════════════════════
-- 🔑 نظام المفاتيح
-- ══════════════════════════════
local function checkKey(input)
    local clean = tostring(input):upper():gsub("%s+", "")
    for _, k in ipairs(CFG.KEYS) do
        if clean == k:upper() then
            return true
        end
    end
    return false
end

local sessionKey = nil
local function getSession() return sessionKey end
local function setSession(k) sessionKey = k end

