local function showSplash(callback)
    if PlayerGui:FindFirstChild("TX9_Splash") then
        PlayerGui.TX9_Splash:Destroy()
    end

    local sg = Instance.new("ScreenGui")
    sg.Name = "TX9_Splash"
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.Parent = PlayerGui

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(4, 4, 14)
    bg.BorderSizePixel = 0
    bg.Parent = sg

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(0, 400, 0, 100)
    title.Position = UDim2.new(0.5, -200, 0.5, -50)
    title.BackgroundTransparency = 1
    title.Text = CFG.NAME
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 50
    title.Font = Enum.Font.GothamBold
    title.TextTransparency = 1
    title.Parent = bg

    local sub = Instance.new("TextLabel")
    sub.Size = UDim2.new(0, 300, 0, 30)
    sub.Position = UDim2.new(0.5, -150, 0.5, 40)
    sub.BackgroundTransparency = 1
    sub.Text = "LOADING..."
    sub.TextColor3 = Color3.fromRGB(0, 200, 255)
    sub.TextSize = 18
    sub.Font = Enum.Font.GothamMedium
    sub.TextTransparency = 1
    sub.Parent = bg

    task.spawn(function()
        for i = 1, 10 do
            pcall(function()
                local dot = Instance.new("TextLabel")
                dot.Size = UDim2.new(0, 8, 0, 8)
                dot.Position = UDim2.new(math.random(), 0, math.random(), 0)
                dot.BackgroundColor3 = i % 2 == 0 and Color3.fromRGB(0, 245, 255) or Color3.fromRGB(255, 0, 110)
                dot.BackgroundTransparency = 0.3
                dot.BorderSizePixel = 0
                dot.Parent = bg
                Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
                game:GetService("Debris"):AddItem(dot, 3)
            end)
            task.wait(0.05)
        end
    end)

    playFX(6042053626, 0.3)

    for i = 1, 30 do
        title.TextTransparency = title.TextTransparency - 0.03
        sub.TextTransparency = sub.TextTransparency - 0.03
        task.wait(0.02)
    end
    title.TextTransparency = 0
    sub.TextTransparency = 0

    task.wait(1.5)

    for i = 1, 30 do
        title.TextTransparency = title.TextTransparency + 0.03
        sub.TextTransparency = sub.TextTransparency + 0.03
        task.wait(0.02)
    end

    sg:Destroy()
    callback()
end

