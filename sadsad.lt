-- كشف وجود Executor
local function isExecutorDetected()
    -- الطريقة 1: كشف الدوال المشبوهة
    local suspiciousGlobals = {
        "syn", "Krnl", "script_context", "getgenv", "getrenv", 
        "getfenv", "loadstring", "hookfunction", "newcclosure",
        "checkcaller", "is_synapse_function", "identifyexecutor"
    }
    
    for _, name in ipairs(suspiciousGlobals) do
        if getfenv()[name] or _G[name] or getgenv and getgenv()[name] then
            return true, name
        end
    end
    
    -- الطريقة 2: كشف بيئة التنفيذ
    local success, err = pcall(function()
        return game:GetService("VirtualUser"):CaptureController()
    end)
    
    if not success then
        return true, "VirtualUser Error"
    end
    
    -- الطريقة 3: كشف التعديل على الميتاتابل
    local success, err = pcall(function()
        local mt = getrawmetatable(game)
        if mt and mt.__namecall then
            return true, "Metatable Hooked"
        end
    end)
    
    return false, nil
end

-- إظهار رسالة للمستخدم
